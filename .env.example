# Supabase (public — used client-side for caching)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# GitHub usernames (public — shown in UI)
NEXT_PUBLIC_GITHUB_USERNAME_PERSONAL=your_personal_username
NEXT_PUBLIC_GITHUB_USERNAME_BUSINESS=your_business_username

# GitHub tokens (server-only — never exposed to browser)
GITHUB_TOKEN_PERSONAL=ghp_...
GITHUB_USERNAME_PERSONAL=your_personal_username
GITHUB_TOKEN_BUSINESS=ghp_...
GITHUB_USERNAME_BUSINESS=your_business_username
